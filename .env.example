# ── LLM provider ──────────────────────────────────────────────────────
# Pick one. The code respects LLM_PROVIDER for KB extraction + reasoning;
# cognee also reads the same vars (it routes through LiteLLM internally).
LLM_PROVIDER=openai          # openai | anthropic
LLM_MODEL=gpt-4o             # gpt-4o, gpt-4-turbo, gpt-4o-mini, claude-sonnet-4-5, ...

# Provide whichever key matches LLM_PROVIDER. The other can be empty.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=

# Cognee picks up LLM_API_KEY directly. Default to the matching key above.
LLM_API_KEY=${OPENAI_API_KEY}

# Optional per-task overrides (default to LLM_MODEL)
EXTRACTION_MODEL=
REASONING_MODEL=

# opencode chat agent — independent of kb-api's extraction/reasoning models.
# Common pairing: cheap model for kb-api's structured passes, stronger model
# for the user-facing chat. Both fall back to LLM_PROVIDER / LLM_MODEL when
# unset. The matching API key (OPENAI_API_KEY / ANTHROPIC_API_KEY above)
# must still be set — opencode reads it from the inherited process env.
OPENCODE_LLM_PROVIDER=
OPENCODE_LLM_MODEL=

# ── Embeddings ─────────────────────────────────────────────────────────
# Two paths supported:
#
# (A) DEFAULT for this POC — local OpenAI-compatible embedding server backed
#     by a sentence-transformers checkpoint you've already downloaded.
#     Use this when HuggingFace network access is blocked.
#     Run: `uv run embedding-server`
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_ENDPOINT=http://127.0.0.1:8766/v1
EMBEDDING_MODEL=local-st
EMBEDDING_API_KEY=no-key-required
EMBEDDING_DIMENSIONS=1024
# Path to your local sentence-transformers checkpoint directory (REQUIRED for option A).
# Recommended: drop the checkpoint under ./models/ in this repo (gitignored).
#   Example: LOCAL_EMBEDDING_MODEL_PATH=./models/qwen3-embedding-0.6B
# Or use an absolute path to a system-wide location:
#   Example: LOCAL_EMBEDDING_MODEL_PATH=/opt/models/qwen3-embedding-0.6B
LOCAL_EMBEDDING_MODEL_PATH=
EMBEDDING_SERVER_HOST=127.0.0.1
EMBEDDING_SERVER_PORT=8766

# Local embedding-server runtime knobs (all optional)
EMBEDDING_DEVICE=auto              # auto | cpu | cuda | cuda:0 | mps
EMBEDDING_NORMALIZE=true           # true → unit vectors (cosine similarity); false → raw vectors
EMBEDDING_BATCH_SIZE=32            # encode() batch size
# EMBEDDING_MAX_SEQ_LEN=8192       # override model's default max input tokens
# EMBEDDING_TRUST_REMOTE_CODE=true # required for some Qwen / custom-arch models
#
# (B) Alternative — fastembed with HF download (works when network reaches HF).
#     Comment out option A above and uncomment these:
# EMBEDDING_PROVIDER=fastembed
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DIMENSIONS=384

# ── Cognee storage ─────────────────────────────────────────────────────
# cognee 1.0 dropped networkx; supported providers are
# neo4j / kuzu / kuzu-remote / postgres / neptune / neptune_analytics.
# kuzu is the embedded option — no server required, just a file under .cognee_data.
GRAPH_DATABASE_PROVIDER=kuzu
VECTOR_DB_PROVIDER=lancedb

# POC is single-user; keep ACL off (it requires neo4j/postgres).
ENABLE_BACKEND_ACCESS_CONTROL=false
# Disable cognee 1.0 session memory cache (optional; keeps demo deterministic).
# CACHING=false

COGNEE_DATA_ROOT=./.cognee_data
COGNEE_SYSTEM_ROOT=./.cognee_system

# ── KB API ─────────────────────────────────────────────────────────────
KB_API_HOST=127.0.0.1
KB_API_PORT=8765
KB_API_BASE_URL=http://127.0.0.1:8765

# ── Mock fab data ──────────────────────────────────────────────────────
MOCK_FAB_DATA_DIR=./data/mock-fab-data

# ── Web UI ─────────────────────────────────────────────────────────────
# When set, /case-study/{id}/open-workspace returns OpenChamber's URL
# instead of opencode's built-in /app. OpenChamber (npm: @openchamber/web,
# repo: github.com/openchamber/openchamber) provides a production-grade
# file tree, diff viewer, and approval UX over the opencode SDK. Install
# via the upstream README — this project does NOT pull or run anything
# from openchamber's repo on your behalf.
#
# scripts/demo.sh starts openchamber as a child process when this var is
# set, configured to attach (OPENCODE_SKIP_START=true) to the opencode
# server kb-api spawns. The `openchamber` CLI must already be on PATH.
OPENCHAMBER_BASE_URL=
# OPENCHAMBER_BASE_URL=http://127.0.0.1:3000
OPENCHAMBER_PORT=3000
OPENCHAMBER_UI_PASSWORD=
# Project-local data dir so we don't pollute ~/.config/openchamber. The
# demo script seeds settings.json:defaultModel here from OPENCODE_LLM_*
# (or LLM_*) — OpenChamber's UI doesn't read opencode's config.model and
# would otherwise show "opencode/big-pickle" as the default.
OPENCHAMBER_DATA_DIR=./data/openchamber

LOG_LEVEL=INFO
