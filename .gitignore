__pycache__/
*.py[cod]
*.egg-info/
.venv/
.env
.env.local

# Cognee local stores
.cognee_data/
.cognee_system/
*.lance/
lancedb/

# Notebook checkpoints
.ipynb_checkpoints/

# OS / editor
.DS_Store
.vscode/
.idea/

# Build artifacts
dist/
build/
.uv-cache/

# Generated mock data (regenerable from generate.py)
# (we DO commit small sample CSVs; comment this out if you want fully ignored)
# data/mock-fab-data/wafer_history.csv
# data/mock-fab-data/defect_counts.csv

# uvicorn / FastAPI
*.log

# Local embedding model checkpoints — too big to commit
*.safetensors
*.bin

# Lifecycle / runtime state — not source. NB: gitignore does NOT support
# inline comments — `pattern  # note` is read as a literal pattern with
# spaces and `#`, matching nothing. Comments must live on their own line.

# Per-case workspaces (ephemeral; recreated per /open-workspace call)
active_sessions/

# Session transcripts (opencode session logs; archived in AutoCRUD)
transcripts/

# Generated final RCA reports (the source-of-truth lives in the KB)
reports/

# AutoCRUD DiskStorageFactory state (case studies, sessions, KB records)
data/autocrud/

# opencode server runtime state (XDG_DATA_HOME — SQLite + snapshots)
data/opencode_data/

# OpenChamber web UI runtime state (settings.json, project icons)
data/openchamber/

.coverage
